{
  "info": {
    "name": "GA7-AA5-EV01-EV02-API-CASO",
    "description": "Coleccion Postman para pruebas de la API independiente de registro e inicio de sesion. Evidencias GA7-220501096-AA5-EV01 y GA7-220501096-AA5-EV02.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "nombre_registro",
      "value": "Mariana Gomez Rojas",
      "type": "string"
    },
    {
      "key": "usuario_registro",
      "value": "",
      "type": "string"
    },
    {
      "key": "email_registro",
      "value": "",
      "type": "string"
    },
    {
      "key": "password_registro",
      "value": "Clave123*",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Ruta raiz",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "02 - Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/health",
          "host": ["{{base_url}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "03 - Registro correcto",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString().slice(-8);",
              "pm.collectionVariables.set('nombre_registro', 'Mariana Gomez Rojas');",
              "pm.collectionVariables.set('usuario_registro', `mariana_gomez_${suffix}`);",
              "pm.collectionVariables.set('email_registro', `mariana.gomez.${suffix}@gmail.com`);",
              "pm.collectionVariables.set('password_registro', 'Clave123*');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"{{nombre_registro}}\",\n  \"usuario\": \"{{usuario_registro}}\",\n  \"email\": \"{{email_registro}}\",\n  \"password\": \"{{password_registro}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "register"]
        }
      }
    },
    {
      "name": "04 - Login correcto",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.token) {",
              "  pm.collectionVariables.set('token', response.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"{{usuario_registro}}\",\n  \"password\": \"{{password_registro}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "05 - Perfil con token",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/profile",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "profile"]
        }
      }
    },
    {
      "name": "06 - Login incorrecto",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"{{usuario_registro}}\",\n  \"password\": \"ClaveIncorrecta\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "07 - Perfil sin token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/auth/profile",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "profile"]
        }
      }
    }
  ]
}
