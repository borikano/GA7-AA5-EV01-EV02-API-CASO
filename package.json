  "scripts": {
    "check:pm": "node -e \"if (!process.env.npm_execpath || !process.env.npm_execpath.includes('pnpm')) { console.error('ERROR: usa pnpm, no npm.'); process.exit(1); }\"",
    "audit:security": "pnpm audit --audit-level moderate && pnpm audit signatures",
    "audit:sbom": "pnpm sbom --format cyclonedx > reports/sbom/sbom.cyclonedx.json",
    "audit:licenses": "pnpm licenses list --json > reports/licenses/licenses.json",
    "audit:outdated": "pnpm outdated",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
